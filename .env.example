# .env.example -- Template des variables d'environnement
# Copier ce fichier en .env et remplir avec vos propres credentials
# Le fichier .env ne doit JAMAIS etre commite (voir .gitignore)

# -- Neon PostgreSQL (production) --
NEON_HOST=votre-endpoint.region.aws.neon.tech
NEON_DBNAME=neondb
NEON_USER=neondb_owner
NEON_PASSWORD=votre_password_ici

